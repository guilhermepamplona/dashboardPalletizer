# ============================================================
# .env.example — KR180 Palletizing Cell Dashboard
# ============================================================
# Copie este arquivo para .env e ajuste os valores:
#   cp .env.example .env
# ============================================================

# ----------------------------------------------------------
# MODO DE OPERAÇÃO
# true  -> simulação local (robô se move sozinho, sem CLP)
# false -> produção (conecta no CLP via python-snap7)
# ----------------------------------------------------------
SIMULATION_MODE=true

# ----------------------------------------------------------
# CONEXÃO COM O CLP (só usado quando SIMULATION_MODE=false)
# ----------------------------------------------------------
PLC_IP=192.168.0.1       # IP do Siemens S7
PLC_RACK=0               # Rack do CLP (normalmente 0)
PLC_SLOT=1               # Slot da CPU (1 para S7-300/400, 0 para S7-1200/1500)

# ----------------------------------------------------------
# DB GENÉRICA DA CÉLULA — AJUSTAR quando a DB for fechada
# no TIA Portal. Veja os offsets em backend/plc_client.py.
# ----------------------------------------------------------
DB_NUMBER=601            # DB601_DashBoard
DB_SIZE=21               # 21 bytes: 10xINT (offsets 0-18) + 1 byte BOOLs (offset 20)

# ----------------------------------------------------------
# POLLING
# Intervalo de leitura do CLP em segundos (0.1 = 10 Hz)
# ----------------------------------------------------------
POLL_INTERVAL_S=0.1

# ----------------------------------------------------------
# SERVIDOR WEB
# ----------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8001
